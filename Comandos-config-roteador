! 1️⃣ Parametros Iniciais e Seguranca
enable
configure terminal
hostname nexus
password Cisco
login
exit

! 2️⃣ Configuracao de IP e Ativacao das Interfaces
interface gigabitEthernet 0/0
 ip address 192.168.1.1 255.255.255.0
 no shutdown
exit

interface gigabitEthernet 0/1
 ip address 192.168.0.1 255.255.255.0
 no shutdown
exit

! 3️⃣ Salvamento de Memoria (RAM para NVRAM)
exit
copy running-config startup-config
